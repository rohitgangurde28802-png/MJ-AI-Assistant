<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <!-- ═══ HUD Status Bar ═══ -->
    <LinearLayout
        android:id="@+id/hudBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <View
            android:id="@+id/statusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/status_dot_green" />

        <TextView
            android:id="@+id/tvStatusHud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="@string/status_online"
            android:textColor="@color/text_mono"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/circle_btn_bg"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="Settings"
            android:padding="8dp"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- ═══ Arc Reactor Orb Area ═══ -->
    <LinearLayout
        android:id="@+id/orbArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/hudBar"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="20dp"
        android:paddingBottom="8dp">

        <!-- Outer glow ring -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center">

            <!-- Glow background -->
            <View
                android:id="@+id/orbGlow"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/orb_glow"
                android:alpha="0.4" />

            <!-- Outer ring -->
            <View
                android:id="@+id/orbRingOuter"
                android:layout_width="184dp"
                android:layout_height="184dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_ring_outer" />

            <!-- Inner ring -->
            <View
                android:id="@+id/orbRingInner"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_ring_inner" />

            <!-- Core sphere -->
            <FrameLayout
                android:id="@+id/orbCore"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                android:background="@drawable/orb_core"
                android:elevation="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/mj_label"
                    android:textColor="@color/bg_dark"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </FrameLayout>
        </FrameLayout>

        <!-- State label -->
        <TextView
            android:id="@+id/tvState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/state_idle"
            android:textColor="@color/arc_cyan"
            android:textSize="12sp"
            android:letterSpacing="0.25"
            android:textStyle="bold" />

        <!-- Busy indicator -->
        <LinearLayout
            android:id="@+id/busyRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressSpinner"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="16dp"
                android:layout_height="16dp" />

            <TextView
                android:id="@+id/tvBusyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="MJ is thinking…"
                android:textColor="@color/thinking_purple"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ Conversation Panel ═══ -->
    <FrameLayout
        android:id="@+id/transcriptPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/orbArea"
        android:layout_above="@id/bottomSection"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/transcript_bg"
        android:padding="2dp">

        <ScrollView
            android:id="@+id/scrollTranscript"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Placeholder text -->
                <TextView
                    android:id="@+id/tvPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/hint_placeholder"
                    android:textColor="@color/text_mono"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:padding="8dp" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- ═══ Bottom Section (Chips + Controls) ═══ -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:paddingBottom="18dp">

        <!-- Quick Action Chips -->
        <HorizontalScrollView
            android:id="@+id/chipsScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingVertical="6dp">

            <LinearLayout
                android:id="@+id/chipsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <!-- Chips added programmatically -->
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Text Input Bar (hidden by default) -->
        <LinearLayout
            android:id="@+id/textInputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/text_input_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etTextInput"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="@string/hint_text_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_mono"
                android:textSize="15sp"
                android:background="@null"
                android:paddingHorizontal="8dp"
                android:imeOptions="actionSend"
                android:inputType="text"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/send_btn_bg"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Send"
                android:padding="8dp"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btnCloseText"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/circle_btn_bg"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Close keyboard"
                android:padding="8dp"
                android:scaleType="centerInside" />
        </LinearLayout>

        <!-- Voice Controls Row -->
        <LinearLayout
            android:id="@+id/voiceControlsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="24dp">

            <!-- Keyboard toggle -->
            <ImageButton
                android:id="@+id/btnKeyboard"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circle_btn_bg"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="Toggle keyboard"
                android:padding="12dp"
                android:scaleType="centerInside" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- MIC FAB -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <!-- Pulse ring animation -->
                <View
                    android:id="@+id/micPulseRing"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/mic_pulse_ring"
                    android:alpha="0"
                    android:layout_gravity="center" />

                <ImageButton
                    android:id="@+id/btnMic"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@drawable/mic_fab_bg"
                    android:src="@android:drawable/ic_btn_speak_now"
                    android:contentDescription="Microphone"
                    android:padding="16dp"
                    android:scaleType="centerInside"
                    android:elevation="10dp" />
            </FrameLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Cancel button -->
            <ImageButton
                android:id="@+id/btnCancel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circle_btn_bg"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="Cancel"
                android:padding="12dp"
                android:scaleType="centerInside" />
        </LinearLayout>

        <!-- Bottom hint -->
        <TextView
            android:id="@+id/tvHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Tap mic to talk · Tap ⌨ to type"
            android:textColor="@color/text_mono"
            android:textSize="11sp"
            android:textAlignment="center"
            android:letterSpacing="0.05" />
    </LinearLayout>

</RelativeLayout>
